{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/api/human-complete-report.schema.json",
  "title": "Human Complete Report",
  "type": "object",
  "description": "User report that a task or work item has been completed outside automation.",
  "additionalProperties": false,
  "properties": {
    "reported_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "subject": { "$ref": "https://schemas.ubunow.net/phase1/common/object-ref.schema.json" },
    "authority_source": { "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json" },
    "note": { "type": "string" }
  },
  "required": ["reported_at", "subject", "authority_source"]
}

