{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/api/bootstrap-response.schema.json",
  "title": "Bootstrap Response",
  "type": "object",
  "description": "Initial API response containing a compact universe state.",
  "additionalProperties": false,
  "properties": {
    "responded_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "state": { "$ref": "https://schemas.ubunow.net/phase1/core/universe-state.schema.json" },
    "errors": {
      "type": "array",
      "items": { "$ref": "https://schemas.ubunow.net/phase1/common/error.schema.json" }
    }
  },
  "required": ["responded_at", "state"]
}

