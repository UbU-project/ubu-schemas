{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/plan.schema.json",
  "title": "Plan",
  "type": "object",
  "description": "A candidate or admitted ordered set of plan steps.",
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" },
    "objective_id": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" },
    "status": { "type": "string", "enum": ["candidate", "admitted", "rejected", "superseded"] },
    "steps": {
      "type": "array",
      "items": { "$ref": "https://schemas.ubunow.net/phase1/planning/plan-step.schema.json" }
    },
    "created_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" }
  },
  "required": ["id", "status", "steps", "created_at"]
}

