{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/candidate-score.schema.json",
  "title": "Candidate Score",
  "type": "object",
  "description": "A bounded score attached to a candidate plan or task option.",
  "additionalProperties": false,
  "properties": {
    "subject": { "$ref": "https://schemas.ubunow.net/phase1/common/object-ref.schema.json" },
    "score": { "type": "number", "minimum": 0, "maximum": 1 },
    "rationale": { "type": "string" }
  },
  "required": ["score"]
}

