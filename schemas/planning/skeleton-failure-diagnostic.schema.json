{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/skeleton-failure-diagnostic.schema.json",
  "title": "Skeleton Failure Diagnostic",
  "type": "object",
  "description": "Minimal diagnostic emitted when a candidate plan skeleton cannot be completed.",
  "additionalProperties": false,
  "properties": {
    "code": { "type": "string", "minLength": 1 },
    "message": { "type": "string", "minLength": 1 },
    "relatedTaskId": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" }
  },
  "required": ["code", "message"]
}

