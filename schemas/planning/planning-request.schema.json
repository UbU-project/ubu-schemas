{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/planning-request.schema.json",
  "title": "Planning Request",
  "type": "object",
  "description": "Input envelope for a planning pass over current universe state and user intent.",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "planning-kernel-contract/0.1" },
    "request_id": { "type": "string", "minLength": 1 },
    "requested_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "authority_source": { "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json" },
    "objective": { "$ref": "https://schemas.ubunow.net/phase1/core/objective.schema.json" },
    "task_specs": {
      "type": "array",
      "items": { "$ref": "https://schemas.ubunow.net/phase1/planning/task-spec.schema.json" }
    },
    "state": { "$ref": "https://schemas.ubunow.net/phase1/core/universe-state.schema.json" },
    "affect_profile": { "$ref": "https://schemas.ubunow.net/phase1/planning/affect-profile.schema.json" },
    "affect_observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": ["live_observation", "bootstrap_default_profile"]
        },
        "observed_at": {
          "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "energy": {
              "$ref": "#/$defs/affect_dimension_observation"
            },
            "stress": {
              "$ref": "#/$defs/affect_dimension_observation"
            },
            "mood_intensity": {
              "$ref": "#/$defs/affect_dimension_observation"
            }
          },
          "required": ["energy", "stress", "mood_intensity"]
        }
      },
      "required": ["source_kind", "observed_at", "dimensions"]
    }
  },
  "required": ["schema_version", "request_id", "requested_at", "authority_source"],
  "$defs": {
    "affect_dimension_observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["energy", "stress", "mood_intensity"]
        },
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        }
      },
      "required": ["dimension", "value"]
    }
  }
}
