{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/task-spec.schema.json",
  "title": "Task Spec",
  "type": "object",
  "description": "Planner-facing task creation or update intent.",
  "additionalProperties": false,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "objectiveId": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" },
    "estimate": { "$ref": "https://schemas.ubunow.net/phase1/common/duration.schema.json" }
  },
  "required": ["title"]
}

