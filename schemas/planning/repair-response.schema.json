{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/repair-response.schema.json",
  "title": "Repair Response",
  "type": "object",
  "description": "Response to a repair request with a repaired plan or remaining diagnostics.",
  "additionalProperties": false,
  "properties": {
    "requestId": { "type": "string", "minLength": 1 },
    "repairedPlan": { "$ref": "https://schemas.ubunow.net/phase1/planning/plan.schema.json" },
    "validation": { "$ref": "https://schemas.ubunow.net/phase1/planning/validation-result.schema.json" }
  },
  "required": ["requestId", "validation"]
}

