{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/planning/repair-response.schema.json",
  "title": "Repair Response",
  "type": "object",
  "description": "Response to a repair request with a repaired plan or remaining diagnostics.",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "planning-kernel-contract/0.1" },
    "request_id": { "type": "string", "minLength": 1 },
    "repaired_plan": { "$ref": "https://schemas.ubunow.net/phase1/planning/plan.schema.json" },
    "validation": { "$ref": "https://schemas.ubunow.net/phase1/planning/validation-result.schema.json" }
  },
  "required": ["schema_version", "request_id", "validation"]
}
