{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/store/candidate-object.schema.json",
  "title": "Candidate Object",
  "type": "object",
  "description": "A proposed object waiting for validation and legitimization.",
  "additionalProperties": false,
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "object_type": { "type": "string", "minLength": 1 },
    "payload": { "type": "object" },
    "submitted_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "authority_source": { "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json" }
  },
  "required": ["candidate_id", "object_type", "payload", "submitted_at", "authority_source"]
}

