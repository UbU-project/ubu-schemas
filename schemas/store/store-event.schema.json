{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/store/store-event.schema.json",
  "title": "Store Event",
  "type": "object",
  "description": "A store-level event describing admission, update, migration, or recalculation.",
  "additionalProperties": false,
  "properties": {
    "event_type": { "type": "string", "enum": ["admitted", "updated", "recalculated", "migrated"] },
    "occurred_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "object": { "$ref": "https://schemas.ubunow.net/phase1/common/object-ref.schema.json" },
    "summary": { "type": "string" }
  },
  "required": ["event_type", "occurred_at"]
}

