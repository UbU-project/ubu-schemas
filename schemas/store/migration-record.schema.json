{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/store/migration-record.schema.json",
  "title": "Migration Record",
  "type": "object",
  "description": "Record of a store migration affecting schema-versioned objects.",
  "additionalProperties": false,
  "properties": {
    "migrationId": { "type": "string", "minLength": 1 },
    "fromVersion": { "type": "string", "minLength": 1 },
    "toVersion": { "type": "string", "minLength": 1 },
    "appliedAt": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "summary": { "type": "string" }
  },
  "required": ["migrationId", "fromVersion", "toVersion", "appliedAt"]
}

