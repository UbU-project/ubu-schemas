{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/store/migration-record.schema.json",
  "title": "Migration Record",
  "type": "object",
  "description": "Record of a store migration affecting schema-versioned objects.",
  "additionalProperties": false,
  "properties": {
    "migration_id": { "type": "string", "minLength": 1 },
    "from_version": { "type": "string", "minLength": 1 },
    "to_version": { "type": "string", "minLength": 1 },
    "applied_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "summary": { "type": "string" }
  },
  "required": ["migration_id", "from_version", "to_version", "applied_at"]
}

