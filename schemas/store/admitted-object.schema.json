{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/store/admitted-object.schema.json",
  "title": "Admitted Object",
  "type": "object",
  "description": "A schema object admitted through an enforcement gate into the store.",
  "additionalProperties": false,
  "properties": {
    "object": { "$ref": "https://schemas.ubunow.net/phase1/common/object-ref.schema.json" },
    "admitted_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "policy_summary": { "$ref": "https://schemas.ubunow.net/phase1/common/policy-summary.schema.json" },
    "provenance": { "$ref": "https://schemas.ubunow.net/phase1/common/provenance.schema.json" }
  },
  "required": ["object", "admitted_at", "provenance"]
}
