{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/common/provenance.schema.json",
  "title": "Provenance",
  "type": "object",
  "description": "Creation, authority path, and source-path metadata for a schema object.",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "authority_source": {
      "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json"
    },
    "source": {
      "$ref": "https://schemas.ubunow.net/phase1/common/source-ref.schema.json"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.ubunow.net/phase1/common/source-ref.schema.json"
      },
      "minItems": 1
    }
  },
  "required": ["created_at", "authority_source"],
  "allOf": [
    {
      "if": {
        "properties": {
          "authority_source": {
            "enum": ["delegated", "automation_worker"]
          }
        },
        "required": ["authority_source"]
      },
      "then": {
        "anyOf": [
          { "required": ["source"] },
          { "required": ["source_refs"] }
        ]
      }
    }
  ]
}
