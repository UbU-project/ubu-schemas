{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/common/id.schema.json",
  "title": "UbU Id",
  "type": "string",
  "description": "Any canonical UbU Phase 1 ID: a known prefix, one underscore delimiter, and a lowercase unhyphenated UUIDv7 suffix.",
  "oneOf": [
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/task_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/objective_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/plan_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/log_entry_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/external_reference_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/compartment_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/snapshot_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/automation_worker_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/projection_preview_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/calendar_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/preference_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/container_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/universe_state_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/identity_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/relationship_id" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/external_event_id" }
  ]
}
