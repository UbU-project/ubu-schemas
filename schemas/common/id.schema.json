{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/common/id.schema.json",
  "title": "UbU Id",
  "type": "string",
  "description": "Any canonical UbU Phase 1 ID: a known prefix, one underscore delimiter, and a lowercase unhyphenated UUIDv7 suffix.",
  "oneOf": [
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/taskId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/objectiveId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/planId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/logEntryId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/externalReferenceId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/compartmentId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/snapshotId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/automationWorkerId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/projectionPreviewId" },
    { "$ref": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json#/$defs/calendarId" }
  ]
}

