{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json",
  "title": "Timestamp",
  "type": "string",
  "description": "RFC 3339 timestamp with an explicit timezone designator or offset. Naive timestamps are invalid.",
  "format": "date-time",
  "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?(?:Z|[+-][0-9]{2}:[0-9]{2})$"
}

