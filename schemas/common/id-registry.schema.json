{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/common/id-registry.schema.json",
  "title": "Id Registry",
  "type": "object",
  "description": "Canonical UbU Phase 1 ID prefix registry, prefix-to-object-type mapping, and UUIDv7 suffix grammar.",
  "additionalProperties": false,
  "properties": {
    "prefix": {
      "$ref": "#/$defs/allowed_prefix"
    },
    "object_type": {
      "$ref": "#/$defs/object_type"
    },
    "id": {
      "$ref": "#/$defs/any_ubu_id"
    }
  },
  "required": ["prefix", "object_type", "id"],
  "allOf": [
    {
      "if": {
        "properties": {
          "prefix": { "const": "task_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Task" },
          "id": { "$ref": "#/$defs/task_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "obj_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Objective" },
          "id": { "$ref": "#/$defs/objective_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "plan_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Plan" },
          "id": { "$ref": "#/$defs/plan_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "log_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "LogEntry" },
          "id": { "$ref": "#/$defs/log_entry_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "xref_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "ExternalReference" },
          "id": { "$ref": "#/$defs/external_reference_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "comp_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Compartment" },
          "id": { "$ref": "#/$defs/compartment_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "snap_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Snapshot" },
          "id": { "$ref": "#/$defs/snapshot_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "worker_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "AutomationWorker" },
          "id": { "$ref": "#/$defs/automation_worker_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "proj_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "ProjectionPreview" },
          "id": { "$ref": "#/$defs/projection_preview_id" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prefix": { "const": "cal_" }
        },
        "required": ["prefix"]
      },
      "then": {
        "properties": {
          "object_type": { "const": "Calendar" },
          "id": { "$ref": "#/$defs/calendar_id" }
        }
      }
    }
  ],
  "$defs": {
    "uuid_v7_suffix": {
      "type": "string",
      "description": "Lowercase unhyphenated UUIDv7 suffix, 32 hex characters.",
      "pattern": "^[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "allowed_prefix": {
      "type": "string",
      "enum": ["task_", "obj_", "plan_", "log_", "xref_", "comp_", "snap_", "worker_", "proj_", "cal_"]
    },
    "object_type": {
      "type": "string",
      "enum": ["Task", "Objective", "Plan", "LogEntry", "ExternalReference", "Compartment", "Snapshot", "AutomationWorker", "ProjectionPreview", "Calendar"]
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "objective_id": {
      "type": "string",
      "pattern": "^obj_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^plan_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "log_entry_id": {
      "type": "string",
      "pattern": "^log_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "external_reference_id": {
      "type": "string",
      "pattern": "^xref_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "compartment_id": {
      "type": "string",
      "pattern": "^comp_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^snap_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "automation_worker_id": {
      "type": "string",
      "pattern": "^worker_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "projection_preview_id": {
      "type": "string",
      "pattern": "^proj_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "calendar_id": {
      "type": "string",
      "pattern": "^cal_[0-9a-f]{12}7[0-9a-f]{3}[89ab][0-9a-f]{15}$"
    },
    "any_ubu_id": {
      "oneOf": [
        { "$ref": "#/$defs/task_id" },
        { "$ref": "#/$defs/objective_id" },
        { "$ref": "#/$defs/plan_id" },
        { "$ref": "#/$defs/log_entry_id" },
        { "$ref": "#/$defs/external_reference_id" },
        { "$ref": "#/$defs/compartment_id" },
        { "$ref": "#/$defs/snapshot_id" },
        { "$ref": "#/$defs/automation_worker_id" },
        { "$ref": "#/$defs/projection_preview_id" },
        { "$ref": "#/$defs/calendar_id" }
      ]
    }
  }
}

