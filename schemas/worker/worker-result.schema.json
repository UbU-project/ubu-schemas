{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/worker/worker-result.schema.json",
  "title": "Worker Result",
  "type": "object",
  "description": "Result envelope returned from an automation worker.",
  "additionalProperties": false,
  "properties": {
    "submission_id": { "type": "string", "minLength": 1 },
    "completed_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "status": { "type": "string", "enum": ["ok", "failed", "needs_review"] },
    "errors": {
      "type": "array",
      "items": { "$ref": "https://schemas.ubunow.net/phase1/common/error.schema.json" }
    }
  },
  "required": ["submission_id", "completed_at", "status"]
}

