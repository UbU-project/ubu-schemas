{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/worker/gpu-advisory-request.schema.json",
  "title": "GPU Advisory Request",
  "type": "object",
  "description": "Request for advisory GPU capacity or scheduling guidance from an automation worker.",
  "additionalProperties": false,
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "requested_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "workload": { "type": "string", "minLength": 1 },
    "estimated_duration": { "$ref": "https://schemas.ubunow.net/phase1/common/duration.schema.json" },
    "max_cost": { "$ref": "https://schemas.ubunow.net/phase1/common/money.schema.json" }
  },
  "required": ["request_id", "requested_at", "workload"]
}

