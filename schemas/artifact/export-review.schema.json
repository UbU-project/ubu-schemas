{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/artifact/export-review.schema.json",
  "title": "Export Review",
  "type": "object",
  "description": "Review record for an artifact export package.",
  "additionalProperties": false,
  "properties": {
    "reviewed_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "reviewer": { "$ref": "https://schemas.ubunow.net/phase1/core/identity.schema.json" },
    "status": { "type": "string", "enum": ["approved", "needs_changes", "blocked"] },
    "notes": { "type": "string" }
  },
  "required": ["reviewed_at", "reviewer", "status"]
}

