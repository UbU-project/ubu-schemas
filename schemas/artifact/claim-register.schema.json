{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/artifact/claim-register.schema.json",
  "title": "Claim Register",
  "type": "object",
  "description": "Register of claims included in an artifact review or publication package.",
  "additionalProperties": false,
  "properties": {
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "claim_id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "required": ["claim_id", "text"]
      }
    }
  },
  "required": ["claims"]
}

