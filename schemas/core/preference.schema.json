{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/preference.schema.json",
  "title": "Preference",
  "type": "object",
  "description": "A user or system preference that can influence planning without becoming runtime logic.",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "value": {
      "type": ["string", "number", "boolean"]
    },
    "authority_source": {
      "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json"
    }
  },
  "required": ["name", "value", "authority_source"]
}

