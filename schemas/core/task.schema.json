{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/task.schema.json",
  "title": "Task",
  "type": "object",
  "description": "A Phase 1 unit of work with canonical lifecycle status, objective linkage, authority, and provenance.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "$ref": "https://schemas.ubunow.net/phase1/core/task-status.schema.json"
    },
    "moot_reason_code": {
      "$ref": "https://schemas.ubunow.net/phase1/core/moot-reason-code.schema.json"
    },
    "objective_id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "assignee": {
      "$ref": "https://schemas.ubunow.net/phase1/core/identity.schema.json"
    },
    "blocked_by": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
      }
    },
    "due_at": {
      "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
    },
    "duration_estimate": {
      "description": "Optional duration model. When absent, downstream planning applies its fixed default.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "fixed"
            },
            "seconds": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "required": ["type", "seconds"]
        },
        {
          "type": "object",
          "description": "A shifted log-normal estimate ordered as 0 <= min_seconds < mode_seconds < p95_seconds.",
          "additionalProperties": false,
          "x-ubu-strictly-increasing": ["min_seconds", "mode_seconds", "p95_seconds"],
          "properties": {
            "type": {
              "type": "string",
              "const": "shifted_lognormal_p95"
            },
            "min_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "mode_seconds": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "p95_seconds": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "required": ["type", "min_seconds", "mode_seconds", "p95_seconds"]
        }
      ]
    },
    "correlation_groups": {
      "type": "array",
      "description": "Optional unsigned correlation memberships. When absent, the Task is independent; group values must be unique within this array.",
      "uniqueItems": true,
      "x-ubu-unique-by": "group",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "group": {
            "type": "string"
          },
          "strength": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "required": ["group", "strength"]
      }
    },
    "preconditions": {
      "$ref": "https://schemas.ubunow.net/phase1/core/precondition.schema.json"
    },
    "effects": {
      "type": "object",
      "description": "Optional predicted mutation of UniverseState if the Task succeeds. When absent, completion mutates nothing.",
      "additionalProperties": false,
      "properties": {
        "success_probability": {
          "description": "Optional planning metadata: probability the Task succeeds, in [0, 1]. May be null.",
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "mutations": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.ubunow.net/phase1/core/universe-state-mutation.schema.json"
          }
        }
      },
      "required": ["mutations"]
    },
    "provenance": {
      "$ref": "https://schemas.ubunow.net/phase1/common/provenance.schema.json"
    }
  },
  "required": ["id", "title", "status", "provenance"],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "const": "moot" }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["moot_reason_code"]
      }
    },
    {
      "if": {
        "properties": {
          "status": { "enum": ["active", "completed", "failed"] }
        },
        "required": ["status"]
      },
      "then": {
        "not": {
          "required": ["moot_reason_code"]
        }
      }
    }
  ]
}
