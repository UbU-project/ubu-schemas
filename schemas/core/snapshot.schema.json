{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/snapshot.schema.json",
  "title": "Snapshot",
  "type": "object",
  "description": "A named point-in-time capture of references, affect observations, and summary metadata.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "captured_at": {
      "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
    },
    "objects": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.ubunow.net/phase1/common/object-ref.schema.json"
      }
    },
    "affect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": ["live_observation", "bootstrap_default_profile"]
        },
        "observed_at": {
          "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
        },
        "dimensions": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "energy": {
              "$ref": "#/$defs/affect_dimension_observation"
            },
            "stress": {
              "$ref": "#/$defs/affect_dimension_observation"
            },
            "mood_intensity": {
              "$ref": "#/$defs/affect_dimension_observation"
            }
          },
          "required": ["energy", "stress", "mood_intensity"]
        }
      },
      "required": ["source_kind", "observed_at", "dimensions"]
    },
    "summary": {
      "type": "string"
    }
  },
  "required": ["id", "captured_at", "objects"],
  "$defs": {
    "affect_dimension_observation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "type": "string",
          "enum": ["energy", "stress", "mood_intensity"]
        },
        "direction": {
          "type": "string",
          "enum": ["higher_is_better", "lower_is_better"]
        },
        "value": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "scale": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "number",
              "const": 0
            },
            "max": {
              "type": "number",
              "const": 10
            }
          },
          "required": ["min", "max"]
        },
        "threshold": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "warning_delta": {
              "type": "number",
              "minimum": 0
            },
            "critical_delta": {
              "type": "number",
              "minimum": 0
            }
          },
          "required": ["warning_delta", "critical_delta"]
        },
        "freshness_seconds": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["dimension", "direction", "value", "scale", "threshold"]
    }
  }
}
