{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/automation-worker.schema.json",
  "title": "Automation Worker",
  "type": "object",
  "description": "A registered automation worker that may submit work under delegated or automation authority.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "registeredAt": {
      "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
    }
  },
  "required": ["id", "name", "capabilities", "registeredAt"]
}

