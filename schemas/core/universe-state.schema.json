{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/universe-state.schema.json",
  "title": "Universe State",
  "type": "object",
  "description": "Canonical Phase 1 UniverseState facts object for planning or API exchange. This is not a snapshot-view placeholder.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "captured_at": {
      "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json"
    },
    "objectives": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.ubunow.net/phase1/core/objective.schema.json"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.ubunow.net/phase1/core/task.schema.json"
      }
    }
  },
  "required": ["id", "captured_at", "objectives", "tasks"]
}
