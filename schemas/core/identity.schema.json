{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/identity.schema.json",
  "title": "Identity",
  "type": "object",
  "description": "A stable actor identity used for attribution, without prescribing an authentication system.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "subject_key": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": ["person", "service", "automation_worker", "system"]
    }
  },
  "required": ["id", "subject_key", "kind"]
}
