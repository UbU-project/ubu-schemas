{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/core/objective.schema.json",
  "title": "Objective",
  "type": "object",
  "description": "A desired outcome that can be decomposed into tasks or plans.",
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["open", "active", "satisfied", "abandoned"]
    },
    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "compartment_id": {
      "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json"
    },
    "provenance": {
      "$ref": "https://schemas.ubunow.net/phase1/common/provenance.schema.json"
    }
  },
  "required": ["id", "title", "status", "provenance"]
}

