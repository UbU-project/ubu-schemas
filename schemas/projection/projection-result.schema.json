{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/projection/projection-result.schema.json",
  "title": "Projection Result",
  "type": "object",
  "description": "Outcome of applying projection operations to an external system.",
  "additionalProperties": false,
  "properties": {
    "preview_id": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" },
    "applied_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "status": { "type": "string", "enum": ["applied", "partial", "failed"] },
    "operation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "operation_id": { "type": "string", "minLength": 1 },
          "status": { "type": "string", "enum": ["applied", "skipped", "failed"] },
          "message": { "type": "string" }
        },
        "required": ["operation_id", "status"]
      }
    }
  },
  "required": ["preview_id", "applied_at", "status", "operation_results"]
}

