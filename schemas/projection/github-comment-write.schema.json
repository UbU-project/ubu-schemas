{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/projection/github-comment-write.schema.json",
  "title": "GitHub Comment Write",
  "type": "object",
  "description": "Requested GitHub issue or pull request comment write payload.",
  "additionalProperties": false,
  "properties": {
    "repository": { "$ref": "https://schemas.ubunow.net/phase1/github/github-repository-source.schema.json" },
    "issueNumber": { "type": "integer", "minimum": 1 },
    "body": { "type": "string", "minLength": 1 }
  },
  "required": ["repository", "issueNumber", "body"]
}

