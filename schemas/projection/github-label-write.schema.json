{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/projection/github-label-write.schema.json",
  "title": "GitHub Label Write",
  "type": "object",
  "description": "Requested GitHub label write payload.",
  "additionalProperties": false,
  "properties": {
    "repository": { "$ref": "https://schemas.ubunow.net/phase1/github/github-repository-source.schema.json" },
    "issueNumber": { "type": "integer", "minimum": 1 },
    "labels": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "required": ["repository", "issueNumber", "labels"]
}

