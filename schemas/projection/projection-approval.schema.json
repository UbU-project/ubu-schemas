{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/projection/projection-approval.schema.json",
  "title": "Projection Approval",
  "type": "object",
  "description": "Human or delegated approval for a projection preview.",
  "additionalProperties": false,
  "properties": {
    "preview_id": { "$ref": "https://schemas.ubunow.net/phase1/common/id.schema.json" },
    "approved": { "type": "boolean" },
    "approved_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" },
    "authority_source": { "$ref": "https://schemas.ubunow.net/phase1/common/authority-source.schema.json" },
    "note": { "type": "string" }
  },
  "required": ["preview_id", "approved", "approved_at", "authority_source"]
}

