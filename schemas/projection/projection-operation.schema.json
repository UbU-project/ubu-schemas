{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/projection/projection-operation.schema.json",
  "title": "Projection Operation",
  "type": "object",
  "description": "A proposed projection write operation to an external system.",
  "additionalProperties": false,
  "properties": {
    "operation_id": { "type": "string", "minLength": 1 },
    "kind": { "type": "string", "enum": ["create", "update", "comment", "label"] },
    "target": { "$ref": "https://schemas.ubunow.net/phase1/common/source-ref.schema.json" },
    "summary": { "type": "string", "minLength": 1 }
  },
  "required": ["operation_id", "kind", "target", "summary"]
}

