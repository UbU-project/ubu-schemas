{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ubunow.net/phase1/github/github-review-source.schema.json",
  "title": "GitHub Review Source",
  "type": "object",
  "description": "Imported GitHub pull request review metadata.",
  "additionalProperties": false,
  "properties": {
    "pull_request": { "$ref": "https://schemas.ubunow.net/phase1/github/github-pr-source.schema.json" },
    "review_id": { "type": "integer", "minimum": 1 },
    "state": { "type": "string", "minLength": 1 },
    "submitted_at": { "$ref": "https://schemas.ubunow.net/phase1/common/timestamp.schema.json" }
  },
  "required": ["pull_request", "review_id", "state"]
}

